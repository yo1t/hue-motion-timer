/*
 * config.h - Configuration file
 *
 * Copy this file to config.h and fill in your values.
 *   cp config.h.example config.h
 *
 * Leave Hue settings empty for auto-setup on M5Stack.
 */

#ifndef CONFIG_H
#define CONFIG_H

// WiFi settings (empty = serial input on boot)
#define WIFI_SSID "your-ssid"
#define WIFI_PASS "your-password"

// Hue Bridge settings (empty = auto-setup)
#define HUE_BRIDGE_IP   ""   // empty = auto-discover
#define HUE_API_KEY     ""   // empty = auto-generate via button press
#define HUE_SENSOR_NAME ""   // empty = select from list on screen

// Polling interval (ms)
#define POLL_INTERVAL 2000

// No-motion reset timeout (ms) - timer resets after this duration of no motion
#define RESET_TIMEOUT 180000

// Speaker volume (0-255)
#define SPEAKER_VOLUME 200

// UI language (0 = Japanese, 1 = English)
#define UI_LANG 0

// Web server URL for remote alerts (empty = disabled)
#define WEB_SERVER_URL ""

// Urgent alert minute (can be overridden from web)
#define DEFAULT_URGENT_MINUTE 20

// Alert schedule (up to 5, set to 0 to disable)
#define ALERT_MIN_1  15
#define ALERT_MIN_2  20
#define ALERT_MIN_3  30
#define ALERT_MIN_4  45
#define ALERT_MIN_5  60

#endif
